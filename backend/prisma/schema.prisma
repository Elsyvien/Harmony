generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum ChannelType {
  PUBLIC
  VOICE
  DIRECT
}

enum ServerVisibility {
  INVITE_ONLY
  PUBLIC
}

enum ModerationActionType {
  WARN
  TIMEOUT
  KICK
  BAN
  UNBAN
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(MEMBER)
  isAdmin        Boolean   @default(false)
  isSuspended    Boolean   @default(false)
  suspendedUntil DateTime?
  createdAt      DateTime  @default(now())
  avatarUrl      String?

  messages         Message[]
  messageReactions MessageReaction[]
  messageReceipts  MessageReceipt[]
  channelMembers   ChannelMember[]
  friendshipsA     Friendship[] @relation("UserA")
  friendshipsB     Friendship[] @relation("UserB")
  friendRequests   Friendship[] @relation("RequestedBy")
  ownedServers     Server[] @relation("ServerOwner")
  serverMemberships ServerMember[]
  createdInvites   ServerInvite[] @relation("ServerInviteCreator")
  moderationActionsAuthored ModerationAction[] @relation("ModerationActionActor")
  moderationActionsTargeted ModerationAction[] @relation("ModerationActionTarget")
  auditLogsAuthored AuditLog[] @relation("AuditLogActor")
  auditLogsTargeted AuditLog[] @relation("AuditLogTarget")
}

model Channel {
  id                String      @id @default(uuid())
  name              String
  type              ChannelType @default(PUBLIC)
  dmKey             String?     @unique
  serverId          String?
  voiceBitrateKbps  Int?
  streamBitrateKbps Int?
  createdAt         DateTime    @default(now())

  server   Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members  ChannelMember[]
  messages Message[]

  @@unique([serverId, name])
  @@index([serverId, type])
}

model ChannelMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  content        String
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentSize Int?
  editedAt       DateTime?
  deletedAt      DateTime?
  replyToMessageId String?
  createdAt      DateTime @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  replyTo   Message?          @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReplies")
  reactions MessageReaction[]
  receipts  MessageReceipt[]

  @@index([channelId, createdAt])
  @@index([replyToMessageId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model MessageReceipt {
  id          String   @id @default(uuid())
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([userId, deliveredAt])
}

model Friendship {
  id            String           @id @default(uuid())
  status        FriendshipStatus @default(PENDING)
  acceptedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  userAId       String
  userA         User             @relation("UserA", fields: [userAId], references: [id], onDelete: Cascade)

  userBId       String
  userB         User             @relation("UserB", fields: [userBId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User             @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model Server {
  id          String           @id @default(uuid())
  slug        String           @unique
  name        String
  description String?
  iconUrl     String?
  tags        String[]         @default([])
  visibility  ServerVisibility @default(INVITE_ONLY)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  ownerId String
  owner   User @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members           ServerMember[]
  channels          Channel[]
  invites           ServerInvite[]
  moderationActions ModerationAction[]
  auditLogs         AuditLog[]
}

model ServerMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role UserRole @default(MEMBER)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([userId])
  @@index([serverId, role])
}

model ServerInvite {
  id        String   @id @default(uuid())
  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
  maxUses   Int?
  usesCount Int      @default(0)
  revokedAt DateTime?

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ServerInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([serverId, revokedAt])
  @@index([expiresAt])
}

model ModerationAction {
  id        String               @id @default(uuid())
  type      ModerationActionType
  reason    String?
  createdAt DateTime             @default(now())
  expiresAt DateTime?

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  actorId String
  actor   User   @relation("ModerationActionActor", fields: [actorId], references: [id], onDelete: Cascade)

  targetUserId String
  targetUser   User   @relation("ModerationActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@index([targetUserId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  targetUserId String?
  targetUser   User?   @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@index([targetUserId, createdAt])
}

model AppSettings {
  id                 String  @id @default("global")
  allowRegistrations Boolean @default(true)
  readOnlyMode       Boolean @default(false)
  slowModeSeconds    Int     @default(0)
  idleTimeoutMinutes Int     @default(15)
  voiceNoiseSuppressionDefault Boolean @default(true)
  voiceEchoCancellationDefault Boolean @default(true)
  voiceAutoGainControlDefault  Boolean @default(true)
}
